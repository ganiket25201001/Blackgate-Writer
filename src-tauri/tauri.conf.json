{
  "package":{
    "productName":"Blackgate Writer",
    "version":"0.1.0"
  },
  "build":{
    "beforeDevCommand":"cd frontend && npm run dev",
    "beforeBuildCommand":"cd frontend && npm run build",
    "devPath":"http://localhost:5173",
    "distDir":"../frontend/dist"
  },
  "tauri":{
    "windows":[{
      "title":"Blackgate Writer",
      "width":1400,
      "height":900,
      "minWidth":1000,
      "minHeight":600,
      "decorations":false,
      "fullscreen":false,
      "resizable":true,
      "alwaysOnTop":false
    }],
    "security":{"csp":null},
    "allowlist":{
      "all":false,
      "shell":{"all":false,"open":true},
      "dialog":{"all":true},
      "fs":{"all":true},
      "window":{"all":true}
    },
    "bundle":{
      "active":true,
      "identifier":"com.blackgate.writer",
      "targets":"all",
      "icon":[
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
